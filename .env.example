# ZeroEntropy API key (single R in "Entropy")
ZEROENTROPY_API_KEY=your_key_here

# Set to "true" to use the in-memory mock for local dev / smoke tests.
# When true, ZEROENTROPY_API_KEY is not required and uploads index against
# an in-process store with a ~150ms simulated indexing latency.
ZERO_ENTROPY_MOCK=false

# Google AI Studio API key for Gemini Flash / Gemma 4 31B (cr_agent
# extraction + outreach draft generation).
# Generate a free key at https://aistudio.google.com/apikey
# If absent, /api/research falls back to a minimal extraction from raw markdown
# (the user still gets a form to edit, just with less pre-filled).
GOOGLE_GENAI_API_KEY=your_key_here

# Optional model override. Default is gemma-4-31b-it (free-tier unlimited
# daily, 15 RPM). Override with gemini-2.5-flash for paid Gemini access.
# GEMINI_MODEL=gemma-4-31b-it

# HogAI (TheHog) — signals fetch + contact enrichment
# Two custom headers, NOT a bearer token.
# Sign up at https://platform.thehog.ai
THEHOG_ACCESS_KEY=ak_your_key_here
THEHOG_SECRET_KEY=sk_your_key_here
THEHOG_BASE_URL=https://developer.thehog.ai

# Set to "true" to use lib/mockHogAI for signals + enrichment instead of
# real HogAI. Useful when you're out of credits or just iterating on UI.
HOGAI_MOCK=false
